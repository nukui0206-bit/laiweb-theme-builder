<script src="//cdnjs.cloudflare.com/ajax/libs/stats.js/r16/Stats.min.js"></script>
<script src="//cdnjs.cloudflare.com/ajax/libs/three.js/87/three.min.js"></script>

<script>
  $(function() {

    $(window).on('load', function() {
      gsap.from('#js-gsap-line1', {
        y: '-50px',
        scrollTrigger: {
          trigger: '#js-gsap-line1',
          start: 'top bottom',
          end: 'bottom top',
          toggleActions: 'play none none none',
          scrub: 2,
          //markers: true,
        },
      });

      gsap.from('#js-gsap-line2', {
        y: '100px',
        scrollTrigger: {
          trigger: '#js-gsap-line2',
          start: 'top bottom',
          end: 'bottom top',
          toggleActions: 'play none none none',
          scrub: 2,
          //markers: true,
        },
      });

      const service = $('#js-gsap-service');
      gsap.to(service, {
        autoAlpha: 1,
        scale: 1,
        scrollTrigger: {
          trigger: '#js-gsap-service',
          start: 'top bottom-=200px',
          end: 'bottom bottom',
          toggleActions: 'play none none none',
          scrub: 2,
          id: 'js-gsap-service',
          //markers: true,
        },
      });

      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: '#js-gsap-about',
          start: 'top top',
          end: () => `+=${about1.innerHeight() * 4}`,
          toggleActions: 'play none none none',
          scrub: 2,
          pin: true,
          invalidateOnRefresh: true,
          anticipatePin: 1,
          //markers: true,
        },
      });

      const about1 = $('.js-gsap-about__image1');
      const about2 = $('.js-gsap-about__image2');
      const about3 = $('.js-gsap-about__image3');
      const about4 = $('.js-gsap-about__image4');

      tl.to(about1, {
          autoAlpha: 0,
          scale: 2,
        })
        .to(about2, {
          autoAlpha: 0,
          scale: 2,
        })
        .to(about3, {
          autoAlpha: 0,
          scale: 2,
        });
    });

    /* ---------------------------------------------------
    mouseover
    ----------------------------------------------------*/
    $(".rotate3d").each(function() {
      $(this)
        .on("mousemove", function(e) {
          var offset = $(this).offset();
          var ax = -($(this).outerWidth() / 2 - (e.pageX - offset.left)) / 10;
          var ay = ($(this).outerHeight() / 2 - (e.pageY - offset.top)) / 20;
          $(this).children().attr("style", "transform: perspective(1000px) scale3d(1, 1, 1) rotateY(" + ax + "deg) rotateX(" + ay + "deg);-webkit-transform: perspective(1000px) scale3d(1, 1, 1) rotateY(" + ax + "deg) rotateX(" + ay + "deg);-moz-transform: perspective(1000px) scale3d(1, 1, 1) rotateY(" + ax + "deg) rotateX(" + ay + "deg)");
        })
        .on("mouseleave", function(e) {
          $(this).children().attr("style", "transform: perspective(1000px) scale3d(1, 1, 1) rotateY(0deg) rotateX(0deg);-webkit-transform: perspective(1000px) scale3d(1, 1, 1) rotateY(0deg) rotateX(0deg);-moz-transform: perspective(1000px) scale3d(1, 1, 1) rotateY(0deg) rotateX(0deg)");
        });
    });

  });
</script>

</body>

</html>